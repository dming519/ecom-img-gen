{
  "name": "ecom-img-gen",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build --preset=cloudflare_pages",
    "start": "nuxt preview",
    "check": "nuxt prepare && vue-tsc --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "preview": "wrangler pages dev dist --project-name ecom-img-gen",
    "deploy:pages": "nuxt build --preset=cloudflare_pages && wrangler pages deploy dist --project-name ecom-img-gen",
    "deploy:worker": "wrangler deploy --config worker/wrangler.toml",
    "deploy": "npm run deploy:pages && npm run deploy:worker"
  },
  "dependencies": {
    "h3": "^1.15.11",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "nuxt": "^4.4.7",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^6.0.227",
    "turndown": "^7.2.4",
    "vue": "^3.5.35",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260521.1",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.6.0",
    "vue-tsc": "^3.3.3",
    "wrangler": "^4.98.0"
  }
}
